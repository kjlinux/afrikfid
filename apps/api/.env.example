# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ─── Base de données PostgreSQL ──────────────────────────────────────────────
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://afrikfid:afrikfid_dev@localhost:5432/afrikfid
# Mettre à true si la connexion PostgreSQL nécessite SSL (ex: Render, Railway, Supabase)
DATABASE_SSL=false
# Mot de passe PostgreSQL (utilisé par docker-compose)
POSTGRES_PASSWORD=afrikfid_dev

# ─── Authentification JWT ────────────────────────────────────────────────────
# IMPORTANT: Changer absolument ces secrets en production !
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=afrikfid-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=afrikfid-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin initial (créé au premier démarrage) ───────────────────────────────
ADMIN_EMAIL=admin@afrikfid.com
ADMIN_PASSWORD=Admin@2026!

# ─── Paiements ───────────────────────────────────────────────────────────────
# true = tous les paiements sont simulés (développement/staging)
SANDBOX_MODE=true
# Commission plateforme par défaut (%)
DEFAULT_PLATFORM_FEE_PERCENT=2

# ─── Webhooks marchands ──────────────────────────────────────────────────────
WEBHOOK_RETRY_MAX=3
WEBHOOK_TIMEOUT_MS=5000
# Secret HMAC pour signer les payloads webhook (X-AfrikFid-Signature)
WEBHOOK_SECRET=afrikfid-webhook-secret-change-in-production

# ─── Rate Limiting — par IP et par clé API) ─────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
# Si l'API est derrière un reverse proxy (Nginx, Kubernetes ingress), activer trust proxy
# TRUST_PROXY=1

# ─── Batch Fidélité — quotidien ou hebdomadaire) ───────────────────
# Valeurs: 'daily' (défaut, tous les jours à 2h) ou 'weekly' (chaque lundi à 2h)
LOYALTY_BATCH_FREQUENCY=daily

# ─── Africa's Talking SMS ────────────────────────────────────────────────────
# Inscription: https://africastalking.com
# En développement, utiliser username=sandbox (pas de SMS réels envoyés)
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=AfrikFid

# ─── SMTP générique (Mailtrap / SendGrid SMTP / tout serveur SMTP) ───────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_FROM=Afrik'Fid <noreply@afrikfid.com>
SMTP_SECURE=false

# ─── Mailgun Email (utilisé si SMTP non configuré) ───────────────────────────
# Inscription: https://mailgun.com
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=Afrik'Fid <noreply@mg.yourdomain.com>

# ─── WhatsApp Business API — Starter Boost+) ──────────────────────
# Choisir un provider : meta (recommandé) ou twilio
WHATSAPP_PROVIDER=meta

# Provider Meta (WhatsApp Business Cloud API)
# Inscription: https://developers.facebook.com/docs/whatsapp/cloud-api
# Récupérer via Meta for Developers > votre app > WhatsApp > API Setup
WHATSAPP_TOKEN=your_meta_whatsapp_permanent_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Optionnel: ID de l'application Facebook (pour vérification webhook)
WHATSAPP_APP_ID=your_facebook_app_id
WHATSAPP_APP_SECRET=your_facebook_app_secret

# Provider Twilio (alternative à Meta)
# Inscription: https://www.twilio.com/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Numéro Twilio WhatsApp sandbox (ex: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Si aucun provider configuré, les notifications WhatsApp sont simulées en console (sandbox mode)

# ─── LAfricaMobile WhatsApp Business API (provider PRINCIPAL) ────────────────
# Doc: https://waba.lafricamobile.com/api-docs/
# Header d'auth: LAM-API-KEY
LAM_BASE_URL=https://waba.lafricamobile.com
LAM_API_KEY=your_lam_api_key
LAM_TIMEOUT_MS=8000
LAM_DEFAULT_COUNTRY_CODE=225

# Template OTP (login)
LAM_OTP_TEMPLATE_NAME=
LAM_OTP_TEMPLATE_NAMESPACE=
LAM_OTP_TEMPLATE_LANGUAGE=fr
LAM_OTP_TEMPLATE_CATEGORY=AUTHENTICATION

# Template marketing générique (campagnes/triggers hors-fenêtre 24h)
LAM_MARKETING_TEMPLATE_NAME=test_nvo_partenaire
LAM_MARKETING_TEMPLATE_NAMESPACE=
LAM_MARKETING_TEMPLATE_LANGUAGE=fr

# ─── CinetPay (Paiement carte — UEMOA + CEMAC) ──────────────────────────────
# Inscription: https://cinetpay.com
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_API_KEY=your_cinetpay_api_key
# URLs de callback (remplacer yourdomain.com par votre domaine)
CINETPAY_NOTIFY_URL=https://yourdomain.com/api/v1/payments/card/notify
CINETPAY_RETURN_URL=https://yourdomain.com/pay/return
# Optionnel: surcharger l'URL API CinetPay (défaut: production)
# CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2

# ─── Redis (sessions / révocation tokens) ────────────────────────────────────
# Si absent, un store in-memory est utilisé (non recommandé en production multi-instance)
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379
# Mot de passe Redis en production (docker-compose.prod.yml)
REDIS_PASSWORD=change_me_in_production

# ─── Chiffrement AES-256 des données sensibles  ──────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_chars_encryption_key_here_change_in_production_000000

# ─── Intégration AfrikFid business-api (fidélité historique) ─────────────────
# Base URL de l'API fidélité (Laravel) — source de vérité des cartes 2014xxxxxxx
BUSINESS_API_URL=http://localhost:8000/api
# Token Sanctum du compte de service dédié à afrikid
BUSINESS_API_TOKEN=your_business_api_service_token
# Secret partagé pour signer les requêtes sortantes (HMAC-SHA256)
BUSINESS_API_HMAC_SECRET=afrikfid-business-hmac-secret-change-in-production
# Timeout des appels business-api (ms) et fenêtre du circuit breaker
BUSINESS_API_TIMEOUT_MS=5000
# Active le flux identité unifiée (rollback rapide si false)
AFRIKFID_UNIFIED_ID=true
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=your_hmac_secret_for_searchable_hashes_change_in_production

# ─── Mobile Money — Orange Money ─────────────────────────────────────────────
# Inscription: https://developer.orange.com/
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_orange_merchant_key

# ─── Mobile Money — MTN MoMo ─────────────────────────────────────────────────
# Inscription: https://momodeveloper.mtn.com/
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user_uuid
MTN_API_KEY=your_mtn_api_key
MTN_BASE_URL=https://proxy.momoapi.mtn.com
MTN_ENVIRONMENT=sandbox
# Clé attendue dans X-Callback-Api-Key des callbacks MTN MoMo
MTN_CALLBACK_API_KEY=your_mtn_callback_api_key

# ─── Mobile Money — M-Pesa (Safaricom Daraja) ────────────────────────────────
# Inscription: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_lipa_na_mpesa_passkey
# Token secret intégré dans le CallBackURL M-Pesa (?token=...) pour valider l'origine des callbacks
MPESA_WEBHOOK_SECRET=your_mpesa_webhook_secret_token
# URL de callback M-Pesa (Daraja STK push callback)
PAYMENT_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mm/mpesa/notify

# ─── Mobile Money — Airtel Money ─────────────────────────────────────────────
# Inscription: https://developers.airtel.africa/
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret

# ─── Mobile Money — Wave ──────────────────────────────────────────────────────
# Inscription: https://business.wave.com/
# Docs: https://docs.wave.com/business-api/
WAVE_API_KEY=your_wave_api_key
# URL de callback Wave (success_url et error_url utilisés dans les sessions Wave)
WAVE_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mm/wave/notify

# ─── Mobile Money — Moov Money ───────────────────────────────────────────────
# Inscription: https://developer.moov.africa/
# Docs: https://developer.moov.africa/
MOOV_CLIENT_ID=your_moov_client_id
MOOV_CLIENT_SECRET=your_moov_client_secret
# URL de callback Moov Money
MOOV_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mm/moov/notify

# ─── Flutterwave (Paiement carte — alternative à CinetPay) ───────────────────
# Inscription: https://dashboard.flutterwave.com/
# Docs: https://developer.flutterwave.com/docs
# Utiliser CARD_PROVIDER=flutterwave pour activer (défaut: cinetpay)
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
# Hash pour valider les webhooks Flutterwave (configurer dans le dashboard)
FLUTTERWAVE_WEBHOOK_HASH=your_flutterwave_webhook_hash
FLUTTERWAVE_NOTIFY_URL=https://yourdomain.com/api/v1/webhooks/flutterwave
FLUTTERWAVE_RETURN_URL=https://yourdomain.com/pay/return

# ─── Fournisseur carte (cinetpay | flutterwave) ───────────────────────────────
# Sélectionne quel provider utiliser pour les paiements carte
# Si le provider sélectionné n'a pas de clés configurées, fallback sur sandbox
CARD_PROVIDER=cinetpay

# ─── CORS — liste blanche des origines autorisées ───────────────────────────
# CSV d'origines autorisées en production. Exemple :
# CORS_ORIGINS=https://app.afrikfid.com,https://admin.afrikfid.com
# Laisser vide pour autoriser toutes les origines en développement (déconseillé en prod)
CORS_ORIGINS=

# ─── 2FA TOTP Admins ────────────────────────────────────────────────────────
# Pas de config requise : les secrets sont générés par admin via /auth/2fa/setup

# ─── Taux de change automatiques ────────────────────────────────────────────
# Open Exchange Rates (gratuit jusqu'à 1000 req/mois): https://openexchangerates.org/
OPENEXCHANGERATES_APP_ID=your_openexchangerates_app_id
# Fixer.io (fallback): https://fixer.io/
FIXER_API_KEY=your_fixer_api_key

# ─── Alertes fraude (email admin) ───────────────────────────────────────────
# Email de l'équipe sécurité pour recevoir les alertes de fraude
ADMIN_ALERT_EMAIL=security@afrikfid.com

# ─── Callbacks opérateurs Mobile Money ──────────────────────────────────────
# Secrets pour vérification des signatures de callbacks entrants
# Si configurés, les callbacks sans signature valide sont rejetés (RECOMMANDÉ en production)
ORANGE_WEBHOOK_SECRET=your_orange_webhook_secret
AIRTEL_WEBHOOK_SECRET=your_airtel_webhook_secret
# Clé secrète CinetPay pour valider la signature cpm_signature des callbacks
CINETPAY_SECRET_KEY=your_cinetpay_secret_key

# ─── URLs et identité (emails) ──────────────────────────────────────────────
# URL du tableau de bord marchand/client
DASHBOARD_URL=https://app.afrikfid.com
# URL du tableau de bord admin (si différent du dashboard principal)
ADMIN_DASHBOARD_URL=https://admin.afrikfid.com
# URL publique du frontend (liens dans emails abonnement)
PUBLIC_WEB_URL=https://app.afrikfid.com

# ─── Emails de contact (configurables par domaine) ──────────────────────────
SUPPORT_EMAIL=support@afrikfid.com
COMPLIANCE_EMAIL=compliance@afrikfid.com
FINANCE_EMAIL=finance@afrikfid.com
SECURITY_EMAIL=security@afrikfid.com

# ─── Logo email (URL publique accessible depuis internet) ───────────────────
# Héberger le logo sur un CDN ou le frontend public (ex: https://app.afrikfid.com/brand/logo.png)
# Si non défini, un logo textuel "Afrik'Fid" est utilisé en fallback
LOGO_URL=https://app.afrikfid.com/brand/logo-text.png

# ─── Docker / Production ─────────────────────────────────────────────────────
# Domaine de déploiement (utilisé par docker-compose.prod.yml)
# DOMAIN=afrikfid.com
# Email pour Let's Encrypt (certificats TLS automatiques)
# ACME_EMAIL=ops@afrikfid.com
# Mot de passe Grafana (défaut: afrikfid_grafana)
# GRAFANA_PASSWORD=change_me_in_production
# Version des images Docker (ex: sha-abc1234 ou latest)
# APP_VERSION=latest

# ============================================================
# ANTHROPIC API — Recommandations IA (PREMIUM package)
# Clé API disponible sur https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
