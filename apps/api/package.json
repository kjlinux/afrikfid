{
  "name": "afrikfid-api",
  "version": "1.0.0",
  "description": "Passerelle de Paiement Afrik'Fid - API Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seed.js",
    "seed:extended": "node src/seed-extended.js",
    "seed:all": "node src/seed.js && node src/seed-extended.js",
    "reset": "node src/resetDb.js",
    "test": "NODE_ENV=test npx jest --forceExit --runInBand",
    "test:watch": "NODE_ENV=test npx jest --watch --runInBand",
    "test:coverage": "NODE_ENV=test npx jest --coverage --forceExit --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/setup/global-setup.js",
    "globalTeardown": "./tests/setup/global-teardown.js",
    "setupFiles": [
      "./tests/setup/setup-env.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/seed.js",
      "!src/resetDb.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.14.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
