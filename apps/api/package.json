{
  "name": "afrikfid-api",
  "version": "1.0.0",
  "description": "Passerelle de Paiement Afrik'Fid - API Backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node --experimental-sqlite src/index.js",
    "dev": "nodemon --exec \"node --experimental-sqlite\" src/index.js",
    "seed": "node --experimental-sqlite src/seed.js",
    "reset": "node --experimental-sqlite src/resetDb.js",
    "test": "NODE_OPTIONS=\"--experimental-sqlite --experimental-vm-modules\" NODE_ENV=test npx jest --forceExit --runInBand",
    "test:watch": "NODE_OPTIONS=\"--experimental-sqlite --experimental-vm-modules\" NODE_ENV=test npx jest --watch --runInBand",
    "test:coverage": "NODE_OPTIONS=\"--experimental-sqlite --experimental-vm-modules\" NODE_ENV=test npx jest --coverage --forceExit --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/seed.js",
      "!src/resetDb.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75
      }
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "dotenv": "^16.4.5",
    "axios": "^1.6.7",
    "cron": "^3.1.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
